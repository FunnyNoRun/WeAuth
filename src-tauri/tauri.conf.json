{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "weauth-tauri",
  "version": "0.1.7",
  "identifier": "com.funnynorun.weauth-tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "weauth-tauri",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
    "plugins": {
      "deep-link": {
        "desktop": {
          "schemes": ["weauth"]
        }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "lib/*": "lib/",
      "*.dat": "./",
      "*.dll": "./"
    }
  }
}
